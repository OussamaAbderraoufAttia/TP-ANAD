# ==============================================================================
# TP : Analyse de Données (ACP & ACM)
# Fichier : data_anad.csv
# ==============================================================================
# 1. Chargement des bibliothèques
if(!require(FactoMineR)) install.packages("FactoMineR")
if(!require(factoextra)) install.packages("factoextra")
if(!require(corrplot)) install.packages("corrplot")
library(FactoMineR)
library(factoextra)
library(corrplot)
# 2. Chargement des données
# On suppose que le fichier est dans le même répertoire que le script
data <- read.csv("data_anad.csv", row.names = 1, stringsAsFactors = TRUE)
# Aperçu des données
cat("Dimensions du tableau : ", dim(data)[1], " individus et ", dim(data)[2], " variables.\n")
str(data)
summary(data)
# 3. Nettoyage et Préparation
# Vérification des valeurs manquantes
sum(is.na(data)) # Affiche le nombre de NA
# Séparation des variables pour les analyses
# Variables Quantitatives : wage, education, experience, age
# Variables Qualitatives : ethnicity, region, gender, occupation, sector, union, married
vars_quanty <- data[, c("wage", "education", "experience", "age")]
vars_qualy <- data[, c("ethnicity", "region", "gender", "occupation", "sector", "union", "married")]
# ==============================================================================
# PARTIE 1 : ANALYSE EN COMPOSANTES PRINCIPALES (ACP)
# Objectif : Analyser les relations entre les variables numériques (Salaire, Age, etc.)
# ==============================================================================
cat("\n--- Lancement de l'ACP ---\n")
# Exécution de l'ACP (on centre et réduit par défaut)
# On peut aussi ajouter les variables qualitatives en tant qu'illustratives (sup)
res.pca <- PCA(data, quanti.sup = NULL, quali.sup = 5:11, graph = FALSE)
# A. Étude de l'inertie (Valeurs propres)
print(fviz_eig(res.pca, addlabels = TRUE, main = "Éboulis des valeurs propres (ACP)"))
# B. Graphique des variables (Cercle des corrélations)
print(fviz_pca_var(res.pca, col.var = "cos2",
             gradient.cols = c("#00AFBB", "#E7B800", "#FC4E07"),
             repel = TRUE,
             title = "Cercle des corrélations - ACP"))
# C. Graphique des individus
print(fviz_pca_ind(res.pca, label = "none", habillage = "gender",
             addEllipses = TRUE, palette = "jco",
             title = "Plan factoriel des individus (coloré par genre)"))
# ==============================================================================
# PARTIE 2 : ANALYSE DES CORRESPONDANCES MULTIPLES (ACM)
# Objectif : Analyser les liens entre les modalités des variables qualitatives
# ==============================================================================
cat("\n--- Lancement de l'ACM ---\n")
# On utilise uniquement les colonnes qualitatives
# Le jeu de données contient 7 variables qualitatives
res.mca <- MCA(vars_qualy, graph = FALSE)
# A. Valeurs propres (ACM)
print(fviz_eig(res.mca, addlabels = TRUE, main = "Inertie des dimensions (ACM)"))
# B. Graphique des modalités (Biplot des catégories)
print(fviz_mca_var(res.mca, col.var = "cos2",
             gradient.cols = c("#00AFBB", "#E7B800", "#FC4E07"), 
             repel = TRUE,
             title = "Nuage des modalités - ACM"))
# C. Description des dimensions
# Permet de voir quelles modalités caractérisent le plus chaque axe
res.desc <- dimdesc(res.mca, axes = c(1,2))
print("Description de la Dimension 1 par les variables :")
print(res.desc[[1]]$category)
# D. Graphique des individus (coloré par une variable au choix, ex: occupation)
print(fviz_mca_ind(res.mca, label = "none", habillage = "occupation",
             addEllipses = TRUE, 
             title = "ACM - Individus groupés par Occupation"))
# ==============================================================================
# FIN DU SCRIPT
# ==============================================================================
cat("\nAnalyses terminées. Veuillez consulter les graphiques générés.\n")
