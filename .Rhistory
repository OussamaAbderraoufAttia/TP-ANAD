# ==============================================================================
# TP ANAD : Script pour l'Analyse en Composantes Principales (ACP)
# ==============================================================================
# 1. Installation et chargement des bibliothèques nécessaires
if(!require(FactoMineR)) install.packages("FactoMineR")
if(!require(factoextra)) install.packages("factoextra")
if(!require(corrplot)) install.packages("corrplot")
library(FactoMineR)
library(factoextra)
library(corrplot)
# 2. Chargement des données
# Utilisation de votre chemin spécifique
data <- read.csv("C:/Users/s/Desktop/TP ANAD/data_anad.csv", 
                 row.names = 1, 
                 stringsAsFactors = TRUE)
# Aperçu pour vérifier que tout est bien chargé
head(data)
summary(data)
# 3. Préparation des données pour l'ACP
# L'ACP ne s'applique qu'aux variables quantitatives.
# Ici : wage, education, experience, age (colonnes 1 à 4)
# On peut garder les autres variables comme variables illustratives (quali.sup)
res.pca <- PCA(data, 
               quali.sup = 5:11,  # Variables qualitatives en supplément (non actives)
               graph = FALSE)
# ==============================================================================
# RÉSULTATS ET GRAPHIQUES
# ==============================================================================
# A. Étude de l'inertie (Éboulis des valeurs propres)
# Cela permet de décider combien d'axes garder pour l'analyse
print(fviz_eig(res.pca, addlabels = TRUE, 
               main = "Éboulis des valeurs propres",
               barfill = "steelblue", barcolor = "white"))
# B. LE CERCLE DES CORRÉLATIONS (Variables)
# Interprétation : 
# - Plus la flèche est longue, mieux la variable est représentée.
# - Un angle petit entre deux flèches = forte corrélation positive.
print(fviz_pca_var(res.pca, 
             col.var = "cos2", # Couleur selon la qualité de représentation
             gradient.cols = c("#00AFBB", "#E7B800", "#FC4E07"),
             repel = TRUE,     # Évite le chevauchement du texte
             title = "Cercle des corrélations - ACP"))
# C. Carte des individus
# Les individus sont colorés ici par leur 'cos2' (qualité de représentation)
print(fviz_pca_ind(res.pca,
             col.ind = "cos2", 
             gradient.cols = c("#00AFBB", "#E7B800", "#FC4E07"),
             label = "none", # "none" pour ne pas surcharger avec 533 noms
             title = "Nuage des individus - ACP"))
# D. Carte des individus avec coloration par groupe (ex: par occupation)
# Très utile pour voir si des groupes de métiers se distinguent sur le plan
print(fviz_pca_ind(res.pca, 
             label = "none", 
             habillage = "occupation", # Colore par la variable 'occupation'
             addEllipses = TRUE,       # Ajoute des ellipses de confiance
             title = "Individus groupés par Occupation"))
# E. Contributions des variables aux axes
# Pour savoir quelles variables "construisent" l'axe 1 et l'axe 2
print(fviz_contrib(res.pca, choice = "var", axes = 1, title = "Contrib. Axe 1"))
print(fviz_contrib(res.pca, choice = "var", axes = 2, title = "Contrib. Axe 2"))
# 4. Export des résultats numériques (optionnel)
# res.pca$eig : valeurs propres
# res.pca$var$coord : coordonnées des variables sur les axes
# res.pca$var$cos2 : qualité de représentation des variables
# ==============================================================================
# TP ANAD : Script ACP avec sauvegarde automatique des graphiques
# ==============================================================================
# 1. Configuration du dossier et des bibliothèques
path_folder <- "C:/Users/s/Desktop/TP ANAD/"
setwd(path_folder) # Définit le dossier de travail
if(!require(FactoMineR)) install.packages("FactoMineR")
if(!require(factoextra)) install.packages("factoextra")
library(FactoMineR)
library(factoextra)
# 2. Chargement des données
data <- read.csv(paste0(path_folder, "data_anad.csv"), 
                 row.names = 1, 
                 stringsAsFactors = TRUE)
# 3. Exécution de l'ACP
# On garde les colonnes 1 à 4 (quantitatives) pour le calcul
# On met les colonnes 5 à 11 (qualitatives) en illustratives
res.pca <- PCA(data, quali.sup = 5:11, graph = FALSE)
# ==============================================================================
# GÉNÉRATION ET SAUVEGARDE DES GRAPHIQUES
# ==============================================================================
# Fonctions pour sauvegarder en haute qualité (PNG)
# A. Éboulis des valeurs propres (Inertie)
png("1_Eboulis_Valeurs_Propres.png", width = 800, height = 600)
print(fviz_eig(res.pca, addlabels = TRUE, main = "Inertie par dimension"))
dev.off()
# B. Cercle des corrélations (Variables)
png("2_Cercle_Correlations.png", width = 800, height = 800)
print(fviz_pca_var(res.pca, 
                   col.var = "cos2", 
                   gradient.cols = c("#00AFBB", "#E7B800", "#FC4E07"),
                   repel = TRUE,
                   title = "Cercle des corrélations (Variables)"))
dev.off()
# C. Contributions des variables à l'Axe 1
png("3_Contribution_Axe1.png", width = 800, height = 600)
print(fviz_contrib(res.pca, choice = "var", axes = 1, fill = "steelblue"))
dev.off()
# D. Contributions des variables à l'Axe 2
png("4_Contribution_Axe2.png", width = 800, height = 600)
print(fviz_contrib(res.pca, choice = "var", axes = 2, fill = "darkred"))
dev.off()
# E. Nuage des individus (coloré par Cos2 - qualité de représentation)
png("5_Individus_Cos2.png", width = 1000, height = 800)
print(fviz_pca_ind(res.pca, 
                   col.ind = "cos2", 
                   gradient.cols = c("#00AFBB", "#E7B800", "#FC4E07"),
                   label = "none", 
                   title = "Nuage des individus (Cos2)"))
dev.off()
# F. Nuage des individus avec Ellipses par Occupation
png("6_Individus_Occupation.png", width = 1000, height = 800)
print(fviz_pca_ind(res.pca, 
                   label = "none", 
                   habillage = "occupation", 
                   addEllipses = TRUE, 
                   title = "Groupes d'individus par métier"))
dev.off()
# G. Nuage des individus avec Ellipses par Genre
png("7_Individus_Genre.png", width = 1000, height = 800)
print(fviz_pca_ind(res.pca, 
                   label = "none", 
                   habillage = "gender", 
                   addEllipses = TRUE, 
                   title = "Groupes d'individus par genre"))
dev.off()
# ==============================================================================
# FIN DU SCRIPT
# ==============================================================================
cat("Terminé ! Les 7 graphiques ont été enregistrés dans :", path_folder, "\n")
# ==============================================================================
# TP ANAD : Script pour l'ACM (Analyse des Correspondances Multiples)
# ==============================================================================
# 1. Préparation des données pour l'ACM
# On sélectionne uniquement les variables qualitatives (colonnes 5 à 11)
vars_qualitatives <- data[, 5:11]
# 2. Exécution de l'ACM
res.mca <- MCA(vars_qualitatives, graph = FALSE)
# ==============================================================================
# GÉNÉRATION ET SAUVEGARDE DES GRAPHIQUES ACM
# ==============================================================================
# A. Éboulis des valeurs propres (Inertie de l'ACM)
png("8_ACM_Inertie.png", width = 800, height = 600)
print(fviz_eig(res.mca, addlabels = TRUE, main = "Inertie des dimensions - ACM"))
dev.off()
# B. Nuage des modalités (Le graphique le plus important)
# Il montre quelles catégories "vont ensemble"
png("9_ACM_Modalites.png", width = 1200, height = 900)
print(fviz_mca_var(res.mca, 
                   col.var = "cos2",
                   gradient.cols = c("#00AFBB", "#E7B800", "#FC4E07"), 
                   repel = TRUE,
                   title = "Liaisons entre les modalités (Catégories)"))
dev.off()
# C. Nuage des individus coloré par une variable (ex: occupation)
png("10_ACM_Individus_Occupation.png", width = 1000, height = 800)
print(fviz_mca_ind(res.mca, 
                   label = "none", 
                   habillage = "occupation", 
                   addEllipses = TRUE,
                   title = "ACM - Individus selon leur métier"))
dev.off()
# D. Description des dimensions (Quelles modalités définissent l'Axe 1 et 2)
# On affiche les résultats dans la console pour votre rapport
cat("\n--- Description de la Dimension 1 (ACM) ---\n")
print(dimdesc(res.mca, axes = 1)$category)
cat("\n--- Description de la Dimension 2 (ACM) ---\n")
print(dimdesc(res.mca, axes = 2)$category)
# ==============================================================================
# FIN DU SCRIPT ACM
# ==============================================================================
cat("\nACM terminée ! Les graphiques 8, 9 et 10 sont dans votre dossier.\n")
q()
